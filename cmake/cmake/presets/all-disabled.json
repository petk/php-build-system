{
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "version": 11,
  "$comment": "Configurations with all PHP extensions and SAPIs disabled except CLI SAPI",
  "configurePresets": [
    {
      "name": "all-disabled",
      "displayName": "All extensions disabled",
      "description": "PHP configuration with all PHP extensions and SAPIs disabled, only with CLI SAPI",
      "binaryDir": "${sourceDir}/php-build/${presetName}",
      "installDir": "/tmp",
      "cacheVariables": {
        "PHP_EXT_COM_DOTNET": false,
        "PHP_EXT_CTYPE": false,
        "PHP_EXT_DOM": false,
        "PHP_EXT_FILEINFO": false,
        "PHP_EXT_FILTER": false,
        "PHP_EXT_ICONV": false,
        "PHP_EXT_LIBXML": false,
        "PHP_EXT_PDO": false,
        "PHP_EXT_PDO_SQLITE": false,
        "PHP_EXT_PHAR": false,
        "PHP_EXT_POSIX": false,
        "PHP_EXT_SESSION": false,
        "PHP_EXT_SIMPLEXML": false,
        "PHP_EXT_SQLITE3": false,
        "PHP_EXT_TOKENIZER": false,
        "PHP_EXT_XML": false,
        "PHP_EXT_XMLREADER": false,
        "PHP_EXT_XMLWRITER": false,

        "PHP_SAPI_CGI": false,
        "PHP_SAPI_PHPDBG": false
      }
    },
    {
      "name": "all-disabled-ts",
      "inherits": "all-disabled",
      "displayName": "Thread safety (ZTS) with all extensions disabled",
      "description": "PHP thread safe (ZTS) build with all PHP extensions and SAPIs disabled, only with CLI SAPI",
      "cacheVariables": {
        "PHP_THREAD_SAFETY": true
      }
    },
    {
      "name": "all-disabled-coverage",
      "inherits": "all-disabled",
      "displayName": "All extensions disabled with code coverage enabled",
      "description": "PHP configuration with code coverage enabled and all PHP extensions and SAPIs disabled, only with CLI SAPI",
      "cacheVariables": {
        "PHP_COVERAGE": true,
        "PHP_CCACHE": false
      }
    }
  ],
  "buildPresets": [
    {
      "name": "all-disabled",
      "configurePreset": "all-disabled",
      "jobs": 0
    },
    {
      "name": "all-disabled-ts",
      "inherits": "all-disabled",
      "configurePreset": "all-disabled-ts"
    },
    {
      "name": "all-disabled-coverage",
      "inherits": "all-disabled",
      "configurePreset": "all-disabled-coverage"
    },
    {
      "name": "all-disabled-coverage-gcovr",
      "inherits": "all-disabled",
      "configurePreset": "all-disabled-coverage",
      "targets": [
        "php_coverage_gcovr_html",
        "php_coverage_gcovr_xml"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "all-disabled",
      "configurePreset": "all-disabled",
      "environment": {
        "SKIP_IO_CAPTURE_TESTS": "1"
      },
      "output": {
        "shortProgress": true,
        "verbosity": "verbose"
      },
      "execution": {
        "jobs": 0
      }
    },
    {
      "name": "all-disabled-ts",
      "inherits": "all-disabled",
      "configurePreset": "all-disabled-ts"
    },
    {
      "name": "all-disabled-coverage",
      "inherits": "all-disabled",
      "configurePreset": "all-disabled-coverage"
    }
  ],
  "workflowPresets": [
    {
      "name": "all-disabled-coverage",
      "steps": [
        {
          "type": "configure",
          "name": "all-disabled-coverage"
        },
        {
          "type": "build",
          "name": "all-disabled-coverage"
        },
        {
          "type": "test",
          "name": "all-disabled-coverage"
        },
        {
          "type": "build",
          "name": "all-disabled-coverage-gcovr"
        }
      ]
    }
  ]
}

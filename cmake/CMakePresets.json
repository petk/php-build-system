{
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "version": 11,
  "$comment": [
    "CMake presets provided by the PHP build system",
    "Basic usage: cmake --list-presets",
    "             cmake --preset <name> [<options>...]",
    "             cmake --build --preset <name> [<options>...]",
    "             ctest --preset <name> [<options>...]"
  ],
  "include": [
    "cmake/presets/all-disabled.json",
    "cmake/presets/all-enabled.json",
    "cmake/presets/windows.json"
  ],
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default PHP configuration",
      "description": "Configuration with commonly used PHP extensions",
      "binaryDir": "${sourceDir}/php-build/${presetName}",
      "installDir": "/tmp"
    },
    {
      "name": "default-ts",
      "inherits": "default",
      "displayName": "Default PHP configuration with thread safety (ZTS)",
      "description": "Configuration with commonly used PHP extensions and thread safety (ZTS)",
      "cacheVariables": {
        "PHP_THREAD_SAFETY": true
      }
    },
    {
      "name": "default-coverage",
      "inherits": "default",
      "displayName": "Default PHP configuration with code coverage",
      "description": "Configuration with commonly used PHP extensions and code coverage",
      "cacheVariables": {
        "PHP_COVERAGE": true,
        "PHP_CCACHE": false
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "jobs": 0
    },
    {
      "name": "default-ts",
      "inherits": "default",
      "configurePreset": "default-ts"
    },
    {
      "name": "default-coverage",
      "inherits": "default",
      "configurePreset": "default-coverage"
    },
    {
      "name": "default-coverage-gcovr",
      "inherits": "default-coverage",
      "targets": [
        "php_coverage_gcovr_html",
        "php_coverage_gcovr_xml"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "environment": {
        "SKIP_IO_CAPTURE_TESTS": "1"
      },
      "output": {
        "shortProgress": true,
        "verbosity": "verbose"
      },
      "execution": {
        "jobs": 0
      }
    },
    {
      "name": "default-ts",
      "inherits": "default",
      "configurePreset": "default-ts"
    },
    {
      "name": "default-coverage",
      "inherits": "default",
      "configurePreset": "default-coverage"
    }
  ],
  "workflowPresets": [
    {
      "name": "default",
      "steps": [
        {
          "type": "configure",
          "name": "default"
        },
        {
          "type": "build",
          "name": "default"
        }
      ]
    },
    {
      "name": "default-with-tests",
      "steps": [
        {
          "type": "configure",
          "name": "default"
        },
        {
          "type": "build",
          "name": "default"
        },
        {
          "type": "test",
          "name": "default"
        }
      ]
    },
    {
      "name": "default-coverage",
      "steps": [
        {
          "type": "configure",
          "name": "default-coverage"
        },
        {
          "type": "build",
          "name": "default-coverage"
        },
        {
          "type": "test",
          "name": "default-coverage"
        },
        {
          "type": "build",
          "name": "default-coverage-gcovr"
        }
      ]
    }
  ]
}

+
+install-cmake:
+	@echo "Installing CMake files:           $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/"
+	@$(mkinstalldirs) $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/modules/PHP/Internal
+	@$(mkinstalldirs) $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/modules/PHP/Package
+	@cd $(top_srcdir)/cmake/modules && \
+	for i in `find . -type f -name 'Find*.cmake' ! -name 'FindPHP.cmake'`; do \
+		$(INSTALL_DATA) $$i $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/modules; \
+	done
+	@cd $(top_srcdir) && \
+	$(INSTALL_DATA) cmake/autotools/PHPConfig.cmake $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP && \
+	$(INSTALL_DATA) cmake/modules/FindPHP.cmake $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP && \
+	$(INSTALL_DATA) cmake/modules/PHP/Internal/* $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/modules/PHP/Internal && \
+	$(INSTALL_DATA) cmake/modules/PHP/Package/* $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/modules/PHP/Package && \
+	$(INSTALL_DATA) cmake/modules/PHP/*.cmake $(INSTALL_ROOT)$(prefix)/lib/cmake/PHP/modules/PHP
